{
  "version": 2,
  "routes": [
    {
      "src": "/api/speak",
      "dest": "/api/speak.js"
    },
    {
      "src": "/api/claude",
      "dest": "/api/claude.js"
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
